<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/fundo_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/texto_branco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Ícone do Carrinho -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_carrinho"
            app:tint="@color/texto_branco" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtIdCarrinho"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carrinho #01"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/texto_branco" />

            <TextView
                android:id="@+id/txtQtdProdutos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 produtos"
                android:textColor="@color/preco_destaque" />

            <TextView
                android:id="@+id/txtTotalCarrinho"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Total: U$ 0.00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_branco" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>